# =============================================================================
# Cheatcode Backend - Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production Docker (docker-compose.yaml), copy to .env.local instead:
#   cp .env.example .env.local
# =============================================================================

# -- Environment Mode --------------------------------------------------------
# "local" for development, "production" for production
ENV_MODE=local

# -- Required: Database (Supabase) -------------------------------------------
# Get these from your Supabase project dashboard: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -- Required: Redis ---------------------------------------------------------
# For Docker Compose: redis://redis:6379
# For local dev with local Redis: redis://localhost:6379
# For Upstash: rediss://your-upstash-url
REDIS_URL=redis://localhost:6379

# -- Required: Sandbox (Daytona) ---------------------------------------------
# Get these from your Daytona dashboard: https://daytona.io
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_SERVER_URL=https://your-daytona-server.com
DAYTONA_TARGET=your-daytona-target

# -- Required: LLM Provider (at least one) -----------------------------------
# OpenRouter (recommended - gives access to 100+ models): https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Or use direct provider keys:
# OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# -- Required: Fast Code Edits (Relace) --------------------------------------
# Get your API key at: https://relace.ai
RELACE_API_KEY=your-relace-api-key

# -- Optional: Authentication (Clerk) ----------------------------------------
# CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# -- Optional: Web Search (Tavily) -------------------------------------------
# TAVILY_API_KEY=tvly-your-tavily-api-key

# -- Optional: Web Scraping (Firecrawl) --------------------------------------
# FIRECRAWL_API_KEY=fc-your-firecrawl-api-key
# FIRECRAWL_URL=https://api.firecrawl.dev

# -- Optional: Deployment (Vercel) -------------------------------------------
# VERCEL_BEARER_TOKEN=your-vercel-token
# VERCEL_TEAM_ID=team_your-vercel-team-id

# -- Optional: Third-Party Integrations (Composio) ---------------------------
# COMPOSIO_API_KEY=your-composio-api-key

# -- Optional: Observability (Langfuse) --------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-your-langfuse-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-langfuse-secret-key
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# -- Optional: Error Tracking (Sentry) ---------------------------------------
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# -- Optional: Billing (Polar) -----------------------------------------------
# POLAR_ACCESS_TOKEN=your-polar-access-token
# POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
# POLAR_ORGANIZATION_ID=your-polar-org-id

# -- Optional: Durable Workflows (Inngest) -----------------------------------
# INNGEST_EVENT_KEY=your-inngest-event-key
# INNGEST_SIGNING_KEY=your-inngest-signing-key

# -- Optional: Email (Mailtrap) ----------------------------------------------
# MAILTRAP_API_TOKEN=your-mailtrap-api-token

# -- Optional: Misc ----------------------------------------------------------
# MODEL_TO_USE=openrouter/google/gemini-2.5-pro
# MCP_CREDENTIAL_ENCRYPTION_KEY=your-encryption-key
# FEATURE_FLAGS_ENABLED=false
# PREVIEW_PROXY_URL=https://preview.trycheatcode.com
# GOOGLE_API_KEY=your-google-api-key
