{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "enabled": true,
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@cheatcode/skills#skills:build"],
      "outputs": ["dist/**", ".next/**", ".wrangler/**"]
    },
    "db:generate": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@cheatcode/skills#skills:build"]
    },
    "lint": {},
    "skills:build": {
      "inputs": ["../../skills/**", "../../scripts/build-skills.ts", "src/types.ts"],
      "outputs": ["src/generated.ts", "src/generated-manifest.ts"]
    },
    "typecheck": {
      "dependsOn": ["^build", "@cheatcode/skills#skills:build"]
    },
    "deploy": {
      "dependsOn": ["build", "typecheck", "lint"],
      "cache": false
    }
  }
}
