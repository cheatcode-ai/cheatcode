# =============================================================================
# Cheatcode Frontend - Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production Docker (docker-compose.yaml), copy to .env.local instead:
#   cp .env.example .env.local
# =============================================================================

# -- Required: Backend API URL ------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# -- Required: Supabase -------------------------------------------------------
# Must match the values in your backend .env
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -- Required: App URLs -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# -- Optional: Authentication (Clerk) -----------------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# -- Optional: Environment Mode -----------------------------------------------
# "local" for development, "production" for production
# Defaults based on NODE_ENV if not set
NEXT_PUBLIC_ENV_MODE=local

# -- Optional: Error Tracking (Sentry) ----------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# -- Optional: Feature Flags --------------------------------------------------
# NEXT_PUBLIC_FEATURE_FLAGS_ENABLED=false
