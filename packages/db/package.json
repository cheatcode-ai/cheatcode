{
  "name": "@cheatcode/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./dist/src/schema/index.d.ts",
      "import": "./dist/src/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cheatcode/billing": "workspace:*",
    "@cheatcode/env": "workspace:*",
    "@cheatcode/types": "workspace:*",
    "drizzle-orm": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
